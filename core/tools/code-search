#!/usr/bin/env python3
# Usage: Core/tools/code-search <query> [--n N] [--lang LANG] [--gh] — search code examples and technical documentation via Exa (default) or GitHub code search (--gh); returns JSON
import argparse, json, sys, urllib.request, urllib.parse, pathlib, os

_CODE_DOMAINS = [
    'github.com', 'stackoverflow.com', 'docs.python.org', 'developer.mozilla.org',
    'learn.microsoft.com', 'pkg.go.dev', 'docs.rs', 'cppreference.com',
    'man7.org', 'khronos.org', 'registry.khronos.org',
]

def _exa_key():
    cfg = pathlib.Path.home() / '.feynman/web-search.json'
    return json.loads(cfg.read_text())['exaApiKey']

def _exa(query, n, lang):
    q = f'{query} {lang}' if lang else query
    payload = {'query': q, 'numResults': n, 'type': 'keyword', 'includeDomains': _CODE_DOMAINS}
    req = urllib.request.Request(
        'https://api.exa.ai/search',
        data=json.dumps(payload).encode(),
        headers={'Content-Type': 'application/json', 'x-api-key': _exa_key()},
        method='POST',
    )
    with urllib.request.urlopen(req, timeout=30) as r:
        return json.loads(r.read())

def _github(query, lang, n):
    token = os.environ.get('GITHUB_TOKEN')
    q = query
    if lang:
        q += f' language:{lang}'
    url = f'https://api.github.com/search/code?q={urllib.parse.quote(q)}&per_page={n}'
    headers = {'User-Agent': 'research-agent', 'Accept': 'application/vnd.github.v3+json'}
    if token:
        headers['Authorization'] = f'token {token}'
    req = urllib.request.Request(url, headers=headers)
    with urllib.request.urlopen(req, timeout=30) as r:
        data = json.loads(r.read())
    return {
        'source': 'github',
        'results': [{'path': i['path'], 'repo': i['repository']['full_name'],
                     'url': i['html_url']} for i in data.get('items', [])],
    }

def main():
    p = argparse.ArgumentParser()
    p.add_argument('query')
    p.add_argument('--n', type=int, default=10)
    p.add_argument('--lang', help='language hint, e.g. python, cpp, cuda, glsl')
    p.add_argument('--gh', action='store_true', help='use GitHub code search instead of Exa')
    args = p.parse_args()

    try:
        if args.gh:
            print(json.dumps(_github(args.query, args.lang, args.n), indent=2))
        else:
            print(json.dumps(_exa(args.query, args.n, args.lang)))
    except Exception as e:
        print(json.dumps({'error': str(e)}), file=sys.stderr)
        sys.exit(1)

if __name__ == '__main__':
    main()
