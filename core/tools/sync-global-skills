#!/usr/bin/env bash
# Usage: core/tools/sync-global-skills [--check] — link workspace-vendored global skills into $HOME
#
# Some skills must be available in EVERY project, not just this workspace — caveman is the case:
# it is a communication mode, so scoping it to one repo would defeat it. Those live under
# core/skills/<name>/ as folder-shaped skills and are exposed by symlink instead of by the
# core/tools/sync-skills mirror (which only handles flat core/skills/*.md → this workspace).
#
# Source of truth stays in the workspace. $HOME holds links, never copies.
#   ~/.agents/skills/<name>       -> core/skills/<name>
#   ~/.claude/skills/<name>       -> ../../.agents/skills/<name>   (existing convention)
#   ~/.claude/hooks/<name>-<h>    -> core/skills/<name>/hooks/<h>  (settings.json paths unchanged)
#
# Run after a fresh clone on a new machine, or after adding a hook file.
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
WORKSPACE="$(cd "$SCRIPT_DIR/../.." && pwd)"
AGENTS_SKILLS="$HOME/.agents/skills"
CLAUDE_DIR="${CLAUDE_CONFIG_DIR:-$HOME/.claude}"

# Folder-shaped skills that are global rather than workspace-scoped.
GLOBAL_SKILLS=(caveman)

rc=0
MODE="${1:-sync}"

link() {  # link <target> <linkname>
  local target="$1" name="$2" existing
  if [[ "$MODE" == "--check" ]]; then
    if [[ ! -L "$name" ]]; then
      if [[ -e "$name" ]]; then echo "NOT A LINK (real file/dir in the way): $name"
      else echo "MISSING link: $name"; fi
      rc=1; return
    fi
    existing="$(readlink "$name")"
    [[ "$existing" == "$target" ]] || { echo "STALE link: $name -> $existing (want $target)"; rc=1; }
    [[ -e "$name" ]] || { echo "BROKEN link (dangling): $name"; rc=1; }
  else
    # Refuse to clobber a real directory — that is someone's un-vendored install.
    if [[ -e "$name" && ! -L "$name" ]]; then
      echo "REFUSING to replace real path (move or delete it first): $name" >&2
      rc=1; return
    fi
    mkdir -p "$(dirname "$name")"
    ln -sfn "$target" "$name"
  fi
}

for skill in "${GLOBAL_SKILLS[@]}"; do
  src="$WORKSPACE/core/skills/$skill"
  if [[ ! -d "$src" ]]; then
    echo "MISSING source: $src" >&2; rc=1; continue
  fi

  link "$src" "$AGENTS_SKILLS/$skill"
  link "../../.agents/skills/$skill" "$CLAUDE_DIR/skills/$skill"

  # Hooks are referenced by absolute path from settings.json, so the link name keeps
  # the flat `<skill>-<hook>` spelling the settings file already uses.
  if [[ -d "$src/hooks" ]]; then
    # Link entrypoints only — the files settings.json actually names. Helper modules
    # are reached by relative require through the link's realpath, and generated
    # .d.ts/jsconfig.json siblings are editor aids, not hooks. An optional
    # hooks/ENTRYPOINTS file declares the list; without it, every .js/.sh is linked.
    if [[ -d "$src/hooks" ]]; then
      entries=()
      if [[ -f "$src/hooks/ENTRYPOINTS" ]]; then
        while IFS= read -r name; do
          [[ -n "$name" && "$name" != \#* ]] && entries+=("$src/hooks/$name")
        done < "$src/hooks/ENTRYPOINTS"
      else
        entries=("$src/hooks"/*.js "$src/hooks"/*.sh)
      fi
      for hook in "${entries[@]}"; do
        [[ -f "$hook" ]] || { echo "MISSING entrypoint: $hook" >&2; rc=1; continue; }
        link "$hook" "$CLAUDE_DIR/hooks/$skill-$(basename "$hook")"
      done
    fi
  fi
done

if [[ "$MODE" == "--check" ]]; then
  [[ $rc -eq 0 ]] && echo "OK: global skill links in sync"
else
  [[ $rc -eq 0 ]] && echo "Linked ${#GLOBAL_SKILLS[@]} global skill(s) into $AGENTS_SKILLS and $CLAUDE_DIR."
fi
exit $rc
