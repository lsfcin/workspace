#!/usr/bin/env bash
# Workspace pre-commit hook
# Location: /mnt/workspace/.hooks/pre-commit
# Applied via: git config --global core.hooksPath /mnt/workspace/.hooks

YELLOW='\033[1;33m'
RED='\033[0;31m'
BOLD='\033[1m'
NC='\033[0m'

WARN_LINES=200
CRITICAL_LINES=300

STAGED=$(git diff --cached --name-only --diff-filter=ACM 2>/dev/null)
[ -z "$STAGED" ] && exit 0

BLOCKED=0

# ── 1. Line-count checks (code files only — not JSON, Markdown, binaries) ─────
CODE_FILES=$(echo "$STAGED" | grep -E '\.(js|ts|tsx|py|dart|html|css|scss)$' | grep -v '\.d\.ts$' || true)

if [ -n "$CODE_FILES" ]; then
  while IFS= read -r file; do
    [ -f "$file" ] || continue
    lines=$(wc -l < "$file")
    if [ "$lines" -ge "$CRITICAL_LINES" ]; then
      printf "${RED}${BOLD}🚨 FILE SIZE — blocked: $file ($lines lines)${NC}\n"
      printf "   Split before committing. File carries too many responsibilities.\n\n"
      BLOCKED=1
    elif [ "$lines" -ge "$WARN_LINES" ]; then
      printf "${YELLOW}⚠  FILE SIZE — check: $file ($lines lines)${NC}\n"
      printf "   Verify single responsibility. Check cohesion and coupling.\n\n"
    fi
  done <<< "$CODE_FILES"
fi

if [ "$BLOCKED" -eq 1 ]; then
  printf "${RED}${BOLD}Commit blocked. Split oversized file(s) before continuing.${NC}\n"
  exit 1
fi

# ── 2. Missing first-line description comment (new files only) ─────────────────
NEW_CODE=$(git diff --cached --name-only --diff-filter=A 2>/dev/null | grep -E '\.(js|ts|tsx|py|dart|html|css)$' | grep -v '\.d\.ts$' || true)
if [ -n "$NEW_CODE" ]; then
  while IFS= read -r f; do
    [ -f "$f" ] || continue
    first=$(head -1 "$f")
    case "$f" in
      *.py)   echo "$first" | grep -qE '^\s*(#|"""|'"''')" || \
                printf "${YELLOW}⚠  No first-line description: $f${NC}\n   Add: # Short description of this module\n\n" ;;
      *.js|*.ts|*.tsx|*.dart) echo "$first" | grep -qE '^\s*//' || \
                printf "${YELLOW}⚠  No first-line description: $f${NC}\n   Add: // Short description of this module\n\n" ;;
      *.css|*.scss) echo "$first" | grep -qE '^\s*/\*' || \
                printf "${YELLOW}⚠  No first-line description: $f${NC}\n   Add: /* Short description of this stylesheet */\n\n" ;;
      *.html) echo "$first" | grep -qE '^\s*<!--' || \
                printf "${YELLOW}⚠  No first-line description: $f${NC}\n   Add: <!-- Short description of this template -->\n\n" ;;
    esac
  done <<< "$NEW_CODE"
fi

# ── 3. Sync CONTEXT.md File Map for all affected directories ───────────────────
if [ -n "$CODE_FILES" ]; then
  while IFS= read -r dir; do
    [ -f "$dir/CONTEXT.md" ] || continue
    python3 /mnt/workspace/.hooks/ctx-sync.py "$dir" 2>/dev/null \
      && git add "$dir/CONTEXT.md" 2>/dev/null || true
  done < <(echo "$CODE_FILES" | xargs -I{} dirname {} | sort -u)
fi

# ── 4. Python → .pyi stubs (mypy stubgen) ─────────────────────────────────────
PY_FILES=$(echo "$STAGED" | grep '\.py$' | grep -v '__pycache__' || true)
if [ -n "$PY_FILES" ]; then
  if ! command -v stubgen &>/dev/null; then
    printf "${YELLOW}⚠  stubgen not found — .pyi stubs skipped. Install: pip install mypy${NC}\n\n"
  else
    while IFS= read -r f; do
      [ -f "$f" ] || continue
      dir=$(dirname "$f")
      if stubgen "$f" -o "$dir" --quiet 2>/dev/null; then
        pyi="${f%.py}.pyi"
        [ -f "$pyi" ] && git add "$pyi"
      else
        printf "${YELLOW}⚠  stubgen failed for $f — .pyi not staged${NC}\n\n"
      fi
    done <<< "$PY_FILES"
  fi
fi

# ── 5. JavaScript → .d.ts (tsc --allowJs via jsconfig.json) ───────────────────
JS_FILES=$(echo "$STAGED" | grep '\.js$' | grep -v '\.min\.js$' | grep -v '\.config\.js$' || true)
if [ -n "$JS_FILES" ]; then
  if ! command -v tsc &>/dev/null; then
    printf "${YELLOW}⚠  tsc not found — .d.ts not generated for JS files.${NC}\n"
    printf "   Install: npm install -g typescript\n\n"
  else
    SEEN_DIRS=""
    while IFS= read -r f; do
      [ -f "$f" ] || continue
      cfg=""
      d=$(dirname "$f")
      while [ "$d" != "." ] && [ "$d" != "/" ]; do
        [ -f "$d/jsconfig.json" ] && cfg="$d/jsconfig.json" && break
        [ -f "$d/tsconfig.json" ] && cfg="$d/tsconfig.json" && break
        d=$(dirname "$d")
      done
      if [ -z "$cfg" ]; then
        printf "${YELLOW}⚠  No jsconfig.json for $f — .d.ts not generated.${NC}\n"
        printf "   Create jsconfig.json with allowJs + declaration settings.\n\n"
        continue
      fi
      proj_dir=$(dirname "$cfg")
      echo "$SEEN_DIRS" | grep -qF "$proj_dir" && continue
      SEEN_DIRS="$SEEN_DIRS $proj_dir"
      if tsc -p "$cfg" --emitDeclarationOnly 2>/dev/null; then
        git add "$proj_dir"/**/*.d.ts 2>/dev/null || true
      else
        printf "${YELLOW}⚠  tsc failed in $proj_dir — .d.ts not generated${NC}\n\n"
      fi
    done <<< "$JS_FILES"
  fi
fi

# ── 6. TypeScript → .d.ts advice ──────────────────────────────────────────────
TS_FILES=$(echo "$STAGED" | grep -E '\.(ts|tsx)$' | grep -v '\.d\.ts$' || true)
if [ -n "$TS_FILES" ]; then
  root=$(git rev-parse --show-toplevel)
  if [ -f "$root/tsconfig.json" ] && ! grep -q '"declarationDir"' "$root/tsconfig.json" 2>/dev/null; then
    printf "${YELLOW}⚠  TypeScript files changed but tsconfig.json has no declarationDir.${NC}\n"
    printf "   See Code/CONTEXT.md § Interface Files.\n\n"
  fi
fi

exit 0
