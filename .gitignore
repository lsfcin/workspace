# Python bytecode
**/__pycache__/
**/*.pyc

# Trash
.Trash-1000/

# OS / Windows artifacts
$RECYCLE.BIN/
System Volume Information/
.fuse_hidden*

# Downloads
Downloads/

# Local working outputs: audit reports, review notes, roadmaps, plan files.
# These are session-local artefacts and must not be versioned here;
# paper-level outputs live inside each project's own repo.
outputs/
**/*audit.md
**/iq-fix-roadmap.md
HANDOFF.md
ROADMAP.md

# Domain folders: track only workspace-structure files by name.
# Project-internal files (STATUS.md, BENCHMARKS.md, etc.) are not workspace
# concerns — they belong to each project's own git repo.

code/*
!code/CONTEXT.md
!code/SETUP.md
!code/SPECS.md
!code/eslint.shared.js
!code/_templates/
code/_templates/*
!code/_templates/*.md

academy/*
!academy/CONTEXT.md
!academy/SETUP.md
!academy/classes/
academy/classes/*
!academy/classes/CONTEXT.md
!academy/lab/
academy/lab/*
!academy/lab/CONTEXT.md
!academy/papers/
academy/papers/*
!academy/papers/CONTEXT.md

branches/*
!branches/CONTEXT.md
!branches/casinhas/
branches/casinhas/*
!branches/casinhas/CONTEXT.md
!branches/financas/
branches/financas/*
!branches/financas/CONTEXT.md
!branches/saude/
branches/saude/*
!branches/saude/CONTEXT.md
!branches/writing/
branches/writing/*
!branches/writing/mantras.md
!branches/writing/drafts/
branches/writing/drafts/*
!branches/writing/drafts/CONTEXT.md

core/*
!core/CONTEXT.md
!core/agents/
!core/flows/
!core/skills/
!core/tools/

models/*
!models/CONTEXT.md

datasets/*
!datasets/CONTEXT.md
!datasets/relativistic_raytracer/
datasets/relativistic_raytracer/*
!datasets/relativistic_raytracer/CONTEXT.md

brain/*
!brain/CONTEXT.md
!brain/FOUNDATIONS.md
!brain/SPECS.md
!brain/GOALS.md
!brain/TODO.md
!brain/ARCHIVE.md
!brain/USER.md
!brain/INBOX.md
!brain/.log/
!brain/attachments/
brain/attachments/*
!brain/attachments/CONTEXT.md
!brain/goals/
brain/goals/*
!brain/goals/*.md
