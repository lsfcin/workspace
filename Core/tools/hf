#!/usr/bin/env python3
# Usage: Core/tools/hf dataset <id> | files <repo> [--type model|dataset|space] | read <repo> <path> — query HuggingFace Hub metadata and file contents; returns JSON
import sys, json, urllib.request

_BASE = 'https://huggingface.co/api'

def _get(url):
    req = urllib.request.Request(url, headers={'User-Agent': 'research-agent'})
    with urllib.request.urlopen(req, timeout=30) as r:
        return json.loads(r.read())

def main():
    if len(sys.argv) < 3:
        print('Usage: Core/tools/hf dataset <id> | files <repo> [--type model|dataset|space] | read <repo> <path>', file=sys.stderr)
        sys.exit(1)

    cmd, arg = sys.argv[1], sys.argv[2]

    try:
        if cmd == 'dataset':
            print(json.dumps(_get(f'{_BASE}/datasets/{arg}'), indent=2))

        elif cmd == 'files':
            rtype = 'models'
            if '--type' in sys.argv:
                t = sys.argv[sys.argv.index('--type') + 1]
                rtype = {'model': 'models', 'dataset': 'datasets', 'space': 'spaces'}.get(t, 'models')
            data = _get(f'{_BASE}/{rtype}/{arg}')
            print(json.dumps({'repo': arg, 'type': rtype, 'files': data.get('siblings', [])}, indent=2))

        elif cmd == 'read':
            if len(sys.argv) < 4:
                print('Usage: Core/tools/hf read <repo> <path>', file=sys.stderr)
                sys.exit(1)
            path = sys.argv[3]
            url = f'https://huggingface.co/{arg}/raw/main/{path}'
            req = urllib.request.Request(url, headers={'User-Agent': 'research-agent'})
            with urllib.request.urlopen(req, timeout=30) as r:
                print(r.read().decode('utf-8', errors='replace'))

        else:
            print(json.dumps({'error': f'unknown command: {cmd}'}), file=sys.stderr)
            sys.exit(1)

    except urllib.error.HTTPError as e:
        print(json.dumps({'error': str(e)}), file=sys.stderr)
        sys.exit(1)
    except Exception as e:
        print(json.dumps({'error': str(e)}), file=sys.stderr)
        sys.exit(1)

if __name__ == '__main__':
    main()
