#!/usr/bin/env python3
# Usage: Core/tools/parse <file> [--pages N-M] — extract readable text from PDF, DOCX, PPTX, or plain text files; returns raw text
import sys, json, pathlib, subprocess, argparse

def _run(cmd):
    r = subprocess.run(cmd, capture_output=True, text=True)
    return r.stdout if r.returncode == 0 else (None, r.stderr)

def _pdf(path, pages):
    cmd = ['pdftotext']
    if pages:
        start, end = pages.split('-')
        cmd += ['-f', start, '-l', end]
    cmd += [str(path), '-']
    r = subprocess.run(cmd, capture_output=True, text=True)
    if r.returncode != 0:
        return None, r.stderr
    return r.stdout, None

def _pandoc(path):
    r = subprocess.run(['pandoc', '-t', 'plain', str(path)], capture_output=True, text=True)
    if r.returncode != 0:
        return None, r.stderr
    return r.stdout, None

def main():
    p = argparse.ArgumentParser()
    p.add_argument('file')
    p.add_argument('--pages', metavar='N-M', help='page range for PDF (e.g. 1-5)')
    args = p.parse_args()

    path = pathlib.Path(args.file)
    if not path.exists():
        print(json.dumps({'error': f'file not found: {args.file}'}), file=sys.stderr)
        sys.exit(1)

    ext = path.suffix.lower()
    if ext == '.pdf':
        text, err = _pdf(path, args.pages)
    elif ext in ('.docx', '.doc', '.pptx', '.ppt', '.odt', '.rtf'):
        text, err = _pandoc(path)
    elif ext in ('.txt', '.md', '.tex', '.csv', '.json', '.yaml', '.yml'):
        text, err = path.read_text(errors='replace'), None
    else:
        print(json.dumps({'error': f'unsupported format: {ext}'}), file=sys.stderr)
        sys.exit(1)

    if err:
        print(json.dumps({'error': err}), file=sys.stderr)
        sys.exit(1)
    print(text)

if __name__ == '__main__':
    main()
