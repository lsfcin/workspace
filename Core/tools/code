#!/usr/bin/env python3
# Usage: Core/tools/code list|read|search <owner/repo> [path|query] [--ref BRANCH] — browse and search GitHub repository files; returns JSON or raw text
import sys, json, urllib.request, urllib.parse, argparse, base64, os

_API = 'https://api.github.com'

def _get(url):
    token = os.environ.get('GITHUB_TOKEN')
    headers = {'User-Agent': 'research-agent', 'Accept': 'application/vnd.github.v3+json'}
    if token:
        headers['Authorization'] = f'token {token}'
    req = urllib.request.Request(url, headers=headers)
    with urllib.request.urlopen(req, timeout=30) as r:
        return json.loads(r.read())

def main():
    p = argparse.ArgumentParser()
    p.add_argument('cmd', choices=['list', 'read', 'search'])
    p.add_argument('repo', help='owner/repo')
    p.add_argument('target', nargs='?', default='', help='path (list/read) or query (search)')
    p.add_argument('--ref', default='', help='branch or commit SHA')
    args = p.parse_args()

    try:
        if args.cmd == 'list':
            url = f'{_API}/repos/{args.repo}/contents/{args.target}'
            if args.ref:
                url += f'?ref={urllib.parse.quote(args.ref)}'
            data = _get(url)
            if isinstance(data, list):
                files = [{'name': f['name'], 'type': f['type'], 'path': f['path'],
                          'size': f.get('size', 0)} for f in data]
                print(json.dumps({'repo': args.repo, 'path': args.target or '/', 'files': files}, indent=2))
            else:
                print(json.dumps(data, indent=2))

        elif args.cmd == 'read':
            url = f'{_API}/repos/{args.repo}/contents/{args.target}'
            if args.ref:
                url += f'?ref={urllib.parse.quote(args.ref)}'
            data = _get(url)
            if data.get('encoding') == 'base64':
                print(base64.b64decode(data['content']).decode('utf-8', errors='replace'))
            else:
                print(data.get('content', ''))

        elif args.cmd == 'search':
            q = urllib.parse.quote(f'{args.target} repo:{args.repo}')
            data = _get(f'{_API}/search/code?q={q}&per_page=10')
            out = [{'path': i['path'], 'url': i['html_url'],
                    'repo': i['repository']['full_name']} for i in data.get('items', [])]
            print(json.dumps({'query': args.target, 'repo': args.repo, 'results': out}, indent=2))

    except urllib.error.HTTPError as e:
        print(json.dumps({'error': str(e), 'detail': e.read().decode()}), file=sys.stderr)
        sys.exit(1)
    except Exception as e:
        print(json.dumps({'error': str(e)}), file=sys.stderr)
        sys.exit(1)

if __name__ == '__main__':
    main()
