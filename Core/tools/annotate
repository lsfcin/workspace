#!/usr/bin/env python3
# Usage: Core/tools/annotate set <id> <note> | get <id> | list | search <query> | delete <id> — persistent paper annotation store keyed by arXiv ID, DOI, or URL; returns JSON
import sys, json, pathlib, argparse, datetime

_STORE = pathlib.Path.home() / '.research' / 'annotations.json'

def _load():
    return json.loads(_STORE.read_text()) if _STORE.exists() else {}

def _save(data):
    _STORE.parent.mkdir(parents=True, exist_ok=True)
    _STORE.write_text(json.dumps(data, indent=2))

def main():
    p = argparse.ArgumentParser()
    sub = p.add_subparsers(dest='cmd')

    s = sub.add_parser('set')
    s.add_argument('id')
    s.add_argument('note')

    g = sub.add_parser('get')
    g.add_argument('id')

    sub.add_parser('list')

    sr = sub.add_parser('search')
    sr.add_argument('query')

    d = sub.add_parser('delete')
    d.add_argument('id')

    args = p.parse_args()

    if args.cmd == 'set':
        data = _load()
        data[args.id] = {'note': args.note, 'updated': datetime.datetime.now().isoformat()[:19]}
        _save(data)
        print(json.dumps({'id': args.id, 'status': 'saved'}))

    elif args.cmd == 'get':
        data = _load()
        entry = data.get(args.id)
        print(json.dumps({'id': args.id, **(entry or {'note': None})}))

    elif args.cmd == 'list':
        data = _load()
        out = [{'id': k, **v} for k, v in data.items()]
        print(json.dumps({'count': len(out), 'annotations': out}, indent=2))

    elif args.cmd == 'search':
        data = _load()
        q = args.query.lower()
        matches = [{'id': k, **v} for k, v in data.items()
                   if q in k.lower() or q in v.get('note', '').lower()]
        print(json.dumps({'query': args.query, 'matches': matches}, indent=2))

    elif args.cmd == 'delete':
        data = _load()
        if args.id in data:
            del data[args.id]
            _save(data)
            print(json.dumps({'id': args.id, 'status': 'deleted'}))
        else:
            print(json.dumps({'id': args.id, 'status': 'not_found'}))

    else:
        p.print_help()
        sys.exit(1)

if __name__ == '__main__':
    main()
