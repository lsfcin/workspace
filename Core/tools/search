#!/usr/bin/env python3
# Usage: Core/tools/search <query> [--n N] [--type neural|keyword] [--since YYYY-MM-DD] [--domains d1,d2] [--content] — web search via Exa; returns JSON results array
import argparse, json, sys, urllib.request, pathlib

def _key():
    cfg = pathlib.Path.home() / '.feynman/web-search.json'
    return json.loads(cfg.read_text())['exaApiKey']

def main():
    p = argparse.ArgumentParser()
    p.add_argument('query')
    p.add_argument('--n', type=int, default=10)
    p.add_argument('--type', choices=['neural', 'keyword'], default='neural', dest='stype')
    p.add_argument('--since', metavar='YYYY-MM-DD')
    p.add_argument('--domains', metavar='d1,d2')
    p.add_argument('--content', action='store_true', help='include full page text')
    args = p.parse_args()

    payload = {'query': args.query, 'numResults': args.n, 'type': args.stype}
    if args.content:
        payload['contents'] = {'text': True}
    if args.domains:
        payload['includeDomains'] = args.domains.split(',')
    if args.since:
        payload['startPublishedDate'] = args.since + 'T00:00:00Z'

    req = urllib.request.Request(
        'https://api.exa.ai/search',
        data=json.dumps(payload).encode(),
        headers={'Content-Type': 'application/json', 'x-api-key': _key()},
        method='POST',
    )
    try:
        with urllib.request.urlopen(req, timeout=30) as r:
            print(r.read().decode())
    except urllib.error.HTTPError as e:
        print(json.dumps({'error': str(e), 'detail': e.read().decode()}), file=sys.stderr)
        sys.exit(1)

if __name__ == '__main__':
    main()
