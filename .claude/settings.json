{
  "permissions": {
    "allow": [
      "Bash(git -C * log *)",
      "Bash(git -C * diff *)",
      "Bash(git -C * status)",
      "Bash(git -C * show *)",
      "Bash(git -C * branch *)",
      "Bash(codegraph sync *)",
      "Bash(codegraph explore *)",
      "Bash(codegraph query *)",
      "Bash(codegraph callers *)",
      "Bash(codegraph node *)",
      "Bash(codegraph status *)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Read|Edit|Write|Grep|NotebookEdit",
        "hooks": [
          {
            "type": "command",
            "command": "python3 /mnt/workspace/.hooks/context-gate.py"
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "python3 /mnt/workspace/.hooks/bash-context-gate.py"
          },
          {
            "type": "command",
            "command": "rtk hook claude"
          }
        ]
      },
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "python3 /mnt/workspace/.hooks/pre-edit.py"
          },
          {
            "type": "command",
            "command": "python3 /mnt/workspace/.hooks/facade-scan.py"
          },
          {
            "type": "command",
            "command": "python3 /mnt/workspace/.hooks/facade-gate.py"
          },
          {
            "type": "command",
            "command": "python3 /mnt/workspace/.hooks/known-bugs-gate.py"
          },
          {
            "type": "command",
            "command": "python3 /mnt/workspace/.hooks/spec-read-gate.py"
          }
        ]
      },
      {
        "matcher": "Read",
        "hooks": [
          {
            "type": "command",
            "command": "bash /mnt/workspace/.hooks/pre-read.sh"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "bash /mnt/workspace/.hooks/post-edit.sh"
          }
        ]
      },
      {
        "matcher": "Read",
        "hooks": [
          {
            "type": "command",
            "command": "python3 /mnt/workspace/.hooks/facade-tracker.py"
          },
          {
            "type": "command",
            "command": "python3 /mnt/workspace/.hooks/context-tracker.py"
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash /mnt/workspace/.hooks/precompact-wipe.sh"
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash /mnt/workspace/.hooks/session-prune.sh"
          },
          {
            "type": "command",
            "command": "python3 /mnt/workspace/.hooks/inbox-nudge.py"
          },
          {
            "type": "command",
            "command": "python3 /mnt/workspace/.hooks/compass-nudge.py"
          }
        ]
      }
    ]
  }
}
